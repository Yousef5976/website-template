{
  "entities": {
    "Reservation": {
      "title": "Reservation",
      "description": "A customer reservation with optional pre-order",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "time": { "type": "string", "description": "HH:MM" },
        "guests": { "type": "string" },
        "occasion": { "type": "string" },
        "notes": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "successful", "unsuccessful", "done"] },
        "tableId": { "type": "string" },
        "createdAt": { "type": "number", "description": "Server timestamp" },
        "cart": { "type": "array" }
      },
      "required": ["name", "phone", "date", "time", "guests", "status"]
    },
    "Table": {
      "title": "Table",
      "description": "A restaurant table",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "User": {
      "title": "User",
      "description": "An admin user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Customer reservations"
    },
    "/tables/{tableId}": {
      "schema": "Table",
      "description": "Restaurant tables"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Admin users"
    }
  }
}
